<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PraktikumSubmit</title>
  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Segoe UI", Arial, sans-serif;
      background: #f3f6fb;
      color: #111827;
    }

    .navbar {
      height: 72px;
      background: #fff;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
    }

    .brand {
      font-size: 22px;
      font-weight: 800;
      color: #0f172a;
    }

    .brand span { color: #2563eb; }

    .nav-link {
      color: #2563eb;
      text-decoration: none;
      font-weight: 700;
      font-size: 14px;
    }

    .layout {
      display: grid;
      grid-template-columns: 1fr 520px;
      min-height: calc(100vh - 72px);
    }

    .hero {
      background: linear-gradient(135deg, #0f172a, #1d4ed8);
      color: white;
      padding: 70px;
      display: flex;
      flex-direction: column;
      justify-content: center;
    }

    .hero-badge {
      width: fit-content;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      color: #dbeafe;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 22px;
    }

    .hero h1 {
      font-size: 46px;
      line-height: 1.12;
      margin: 0 0 18px;
      letter-spacing: -1px;
    }

    .hero p {
      font-size: 17px;
      line-height: 1.7;
      color: #dbeafe;
      margin: 0;
    }

    .features {
      margin-top: 34px;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 14px;
    }

    .feature {
      background: rgba(255, 255, 255, 0.12);
      border: 1px solid rgba(255, 255, 255, 0.16);
      padding: 16px;
      border-radius: 14px;
      font-size: 14px;
      color: #eff6ff;
    }

    .form-area {
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 42px;
    }

    .card {
      width: 100%;
      background: #fff;
      border-radius: 22px;
      padding: 30px;
      box-shadow: 0 22px 50px rgba(15, 23, 42, 0.12);
      border: 1px solid #eef2f7;
    }

    .card-header h2 {
      margin: 0;
      font-size: 24px;
    }

    .card-header p {
      margin: 8px 0 24px;
      color: #6b7280;
      font-size: 14px;
    }

    label {
      display: block;
      margin: 15px 0 7px;
      color: #374151;
      font-weight: 700;
      font-size: 14px;
    }

    input, select {
      width: 100%;
      padding: 13px 14px;
      border: 1px solid #d1d5db;
      border-radius: 12px;
      font-size: 15px;
      outline: none;
    }

    input:focus, select:focus {
      border-color: #2563eb;
      box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.13);
    }

    input[type="file"] {
      background: #f8fafc;
      cursor: pointer;
    }

    .submit-btn {
      width: 100%;
      margin-top: 24px;
      padding: 14px;
      border: none;
      border-radius: 13px;
      background: #2563eb;
      color: white;
      font-size: 16px;
      font-weight: 800;
      cursor: pointer;
    }

    .submit-btn:hover {
      background: #1d4ed8;
    }

    .alert-success, .alert-error {
      margin-top: 18px;
      padding: 13px 14px;
      border-radius: 12px;
      font-weight: 700;
      font-size: 14px;
      text-align: center;
    }

    .alert-success {
      background: #ecfdf5;
      color: #047857;
      border: 1px solid #a7f3d0;
    }

    .alert-error {
      background: #fef2f2;
      color: #b91c1c;
      border: 1px solid #fecaca;
    }

    .footer-link {
      margin-top: 22px;
      text-align: center;
    }

    .footer-link a {
      color: #2563eb;
      font-weight: 800;
      text-decoration: none;
    }

    @media (max-width: 980px) {
      .layout { grid-template-columns: 1fr; }
      .hero { padding: 48px 28px; }
      .hero h1 { font-size: 34px; }
      .features { grid-template-columns: 1fr; }
      .form-area { padding: 28px; }
      .navbar { padding: 0 24px; }
    }
  </style>
</head>

<body>
  <nav class="navbar">
    <div class="brand">Praktikum<span>Submit</span></div>
    <a class="nav-link" href="/task-list">Lihat Daftar Tugas</a>
  </nav>

  <main class="layout">
    <section class="hero">
      <div class="hero-badge">Azure Cloud Service</div>
      <h1>Pengumpulan Tugas Praktikum Berbasis Cloud</h1>
      <p>
        Aplikasi ini menggunakan Azure App Service, Azure Database for MySQL,
        dan Azure Blob Storage untuk proses pengumpulan tugas.
      </p>

      <div class="features">
        <div class="feature">Data tersimpan di Azure MySQL</div>
        <div class="feature">File tersimpan di Azure Blob Storage</div>
        <div class="feature">Aplikasi berjalan melalui App Service</div>
        <div class="feature">Project ID: 0920240027</div>
      </div>
    </section>

    <section class="form-area">
      <div class="card">
        <div class="card-header">
          <h2>Form Pengumpulan Tugas</h2>
          <p>Lengkapi data berikut lalu unggah file tugas praktikum.</p>
        </div>

        <form action="/submit-task" method="POST" enctype="multipart/form-data">
          <label>NIM</label>
          <input type="text" name="nim" value="0920240027" required>

          <label>Nama Mahasiswa</label>
          <input type="text" name="name" value="Gumelar Akhirul Ramadhan" required>

          <label>Kelas</label>
          <input type="text" name="kelas" value="TRPL 2B" required>

          <label>Mata Kuliah</label>
          <select name="course" required>
            <option value="Cloud Computing">Cloud Computing</option>
            <option value="Basis Data">Basis Data</option>
            <option value="Pemrograman Web">Pemrograman Web</option>
            <option value="Serverless Computing">Serverless Computing</option>
          </select>

          <label>Upload File Tugas</label>
          <input type="file" name="file" required>

          <button class="submit-btn" type="submit">Kumpulkan Tugas</button>
        </form>

        <% if (message) { %>
          <div class="alert-success"><%= message %></div>
        <% } %>

        <% if (error) { %>
          <div class="alert-error"><%= error %></div>
        <% } %>

        <div class="footer-link">
          <a href="/task-list">Lihat daftar pengumpulan</a>
        </div>
      </div>
    </section>
  </main>
</body>
</html>