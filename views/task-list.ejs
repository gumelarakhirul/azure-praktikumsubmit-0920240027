<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Daftar Pengumpulan - PraktikumSubmit</title>

  <style>
    * { box-sizing: border-box; }

    body {
      margin: 0;
      font-family: "Segoe UI", Arial, sans-serif;
      background: #f3f6fb;
      color: #111827;
    }

    .navbar {
      height: 72px;
      background: #fff;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 48px;
    }

    .brand {
      font-weight: 800;
      font-size: 22px;
      color: #0f172a;
    }

    .brand span { color: #2563eb; }

    .nav-link {
      text-decoration: none;
      color: #2563eb;
      font-weight: 800;
      font-size: 14px;
    }

    .hero {
      padding: 46px 48px 72px;
      background: linear-gradient(135deg, #0f172a, #1d4ed8);
      color: white;
    }

    .hero-badge {
      width: fit-content;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.14);
      color: #dbeafe;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 18px;
    }

    .hero h1 {
      margin: 0;
      font-size: 36px;
    }

    .hero p {
      margin: 10px 0 0;
      color: #dbeafe;
      line-height: 1.6;
    }

    .content {
      max-width: 1200px;
      margin: -40px auto 48px;
      padding: 0 28px;
    }

    .summary {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-bottom: 22px;
    }

    .summary-card {
      background: #fff;
      border-radius: 18px;
      padding: 20px;
      box-shadow: 0 14px 34px rgba(15, 23, 42, 0.1);
      border: 1px solid #eef2f7;
    }

    .summary-card span {
      display: block;
      color: #64748b;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 8px;
    }

    .summary-card strong {
      font-size: 26px;
      color: #0f172a;
    }

    .card {
      background: #fff;
      border-radius: 20px;
      box-shadow: 0 18px 45px rgba(15, 23, 42, 0.12);
      overflow: hidden;
      border: 1px solid #eef2f7;
    }

    .card-header {
      padding: 22px 26px;
      border-bottom: 1px solid #e5e7eb;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 16px;
    }

    .card-header h2 {
      margin: 0;
      font-size: 20px;
    }

    .badge-total {
      background: #eff6ff;
      color: #1d4ed8;
      padding: 8px 14px;
      border-radius: 999px;
      font-weight: 800;
      font-size: 13px;
    }

    .table-wrapper {
      overflow-x: auto;
    }

    table {
      width: 100%;
      border-collapse: collapse;
      min-width: 980px;
    }

    th {
      background: #f8fafc;
      color: #475569;
      text-align: left;
      padding: 15px 18px;
      font-size: 12px;
      text-transform: uppercase;
      letter-spacing: .05em;
      border-bottom: 1px solid #e5e7eb;
    }

    td {
      padding: 16px 18px;
      border-bottom: 1px solid #eef2f7;
      font-size: 14px;
      vertical-align: middle;
    }

    tr:hover { background: #f9fbff; }

    .status {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 7px 12px;
      border-radius: 999px;
      background: #ecfdf5;
      color: #047857;
      font-weight: 800;
      font-size: 12px;
    }

    .status::before {
      content: "";
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: #10b981;
    }

    .download {
      display: inline-block;
      background: #2563eb;
      color: white;
      text-decoration: none;
      padding: 9px 13px;
      border-radius: 10px;
      font-weight: 800;
      font-size: 13px;
    }

    .download:hover { background: #1d4ed8; }

    .empty {
      padding: 46px;
      text-align: center;
      color: #64748b;
    }

    @media (max-width: 768px) {
      .navbar { padding: 0 22px; }
      .hero { padding: 36px 22px 64px; }
      .hero h1 { font-size: 28px; }
      .content { padding: 0 18px; }
      .summary { grid-template-columns: 1fr; }
      .card-header {
        flex-direction: column;
        align-items: flex-start;
      }
    }
  </style>
</head>

<body>
  <nav class="navbar">
    <div class="brand">Praktikum<span>Submit</span></div>
    <a class="nav-link" href="/submit-task">+ Submit Tugas</a>
  </nav>

  <section class="hero">
    <div class="hero-badge">Dashboard Admin</div>
    <h1>Daftar Pengumpulan Tugas</h1>
    <p>Monitoring data tugas mahasiswa yang tersimpan melalui Azure Database for MySQL dan Azure Blob Storage.</p>
  </section>

  <main class="content">
    <section class="summary">
      <div class="summary-card">
        <span>Total Pengumpulan</span>
        <strong><%= rows.length %></strong>
      </div>

      <div class="summary-card">
        <span>Status Aktif</span>
        <strong>Submitted</strong>
      </div>

      <div class="summary-card">
        <span>Project ID</span>
        <strong>0920240027</strong>
      </div>
    </section>

    <section class="card">
      <div class="card-header">
        <h2>Data Pengumpulan</h2>
        <div class="badge-total">Total: <%= rows.length %> data</div>
      </div>

      <% if (rows.length === 0) { %>
        <div class="empty">Belum ada data pengumpulan tugas.</div>
      <% } else { %>
        <div class="table-wrapper">
          <table>
            <thead>
              <tr>
                <th>ID</th>
                <th>NIM</th>
                <th>Nama</th>
                <th>Kelas</th>
                <th>Mata Kuliah</th>
                <th>Status</th>
                <th>Waktu Submit</th>
                <th>File</th>
              </tr>
            </thead>

            <tbody>
              <% rows.forEach(row => { %>
                <tr>
                  <td><%= row.id %></td>
                  <td><%= row.nim %></td>
                  <td><%= row.name %></td>
                  <td><%= row.class %></td>
                  <td><%= row.course %></td>
                  <td><span class="status"><%= row.status %></span></td>
                  <td><%= row.submitted_at %></td>
                  <td>
                  <a class="download" href="/task-detail/<%= row.id %>">Detail</a>
                  <a class="download" href="<%= row.file_url %>" target="_blank">Download</a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </section>
  </main>
</body>
</html>